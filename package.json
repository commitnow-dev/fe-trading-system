{
  "name": "fe-trading-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check --config ../.prettier.config.ts",
    "format:write": "prettier . --write --config ../.prettier.config.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write --config ../.prettier.config.ts"
    ],
    "*.{js,json,md,css,html,yml,yaml}": [
      "prettier --write --config ../.prettier.config.ts"
    ]
  }
}
